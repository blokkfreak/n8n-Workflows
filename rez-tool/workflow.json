      "parameters": {
        "jsCode": "const cleaningData = $('Cleaning').item.json;\nlet text = $('Review Schreiber Kritisch 2').first().json.content || '';\n\n// Rekursive Reinigung von allen Labels\nlet oldText;\ndo {\n  oldText = text;\n  text = text\n    .replace(/^[\\s\\S]*?(Rezension|Review|Output|Input|Sterne|Feedback|Kommentar|Vorschlag|Ergebnis|Zusammenfassung).*?[:\\-]+\\s*/si, '')\n    .trim();\n} while (text !== oldText);\n\nconst criticalReview = text\n  .replace(/---/g, '')\n  .replace(/^[\\s\"'„&]+|[\\s\"'“]+$/g, '')\n  .trim();\n\nreturn [{\n  json: {\n    ...cleaningData,\n    success: true,\n    ai_generated_review: '', // Bleibt leer für den Haupt-Output\n    google_review_link: '',\n    has_gbp_link: false,\n    support_forwarded: true,\n    company_name: cleaningData.company_name || cleaningData.company,\n    critical_review_output: criticalReview\n  }\n}];\n"
