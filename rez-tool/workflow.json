        "fromEmail": "hello@your-agency.com",
        "toEmail": "={{ $('Websiteanbindung').item.json.body.email }}\n",
        "subject": "Rezension",
        "html": "=<!DOCTYPE html>\n<html lang=\"de\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>Deine Google-Rezension</title>\n</head>\n<body style=\"margin:0; padding:0; background-color:#f4f4f4; font-family: Arial, Helvetica, sans-serif;\">\n  <table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" role=\"presentation\" style=\"background-color:#f4f4f4;\">\n    <tr>\n      <td align=\"center\" style=\"padding: 32px 16px;\">\n        <table width=\"600\" cellpadding=\"0\" cellspacing=\"0\" role=\"presentation\" style=\"max-width:600px; width:100%; background-color:#ffffff; border-radius:8px; overflow:hidden;\">\n          <tr>\n            <td style=\"background-color:#CF2030; padding: 28px 32px; text-align:center;\">\n              <h1 style=\"margin:0; color:#ffffff; font-size:22px; font-weight:700; letter-spacing:0.5px;\">Deine Rezension ist fertig!</h1>\n            </td>\n          </tr>\n          <tr>\n            <td style=\"padding: 32px;\">\n              <p style=\"margin:0 0 16px; font-size:14px; color:#333333;\">Hallo {{ $('Cleaning').item.json.name }},</p>\n              <p style=\"margin:0 0 24px; font-size:14px; color:#333333;\">auf Basis deiner Angaben haben wir deine {{ $('Cleaning').item.json.rating }}-Rezension vorbereitet. Kopiere den Text einfach und veröffentliche ihn direkt auf Google.</p>\n              <table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" role=\"presentation\" style=\"margin: 0 0 24px;\">\n                <tr>\n                  <td style=\"background-color:#f9f9f9; border-left: 4px solid #CF2030; padding: 20px 20px 20px 16px; border-radius:0 4px 4px 0;\">\n                    <p style=\"margin:0; font-size:14px; color:#333333; line-height:1.7; font-style:italic;\">{{ $json.ai_generated_review }}</p>\n                  </td>\n                </tr>\n              </table>\n              <p style=\"margin:0 0 12px; font-size:14px; color:#333333; font-weight:700;\">So geht's:</p>\n              <ol style=\"margin:0 0 24px; padding-left:20px; font-size:14px; color:#333333;\">\n                <li style=\"margin-bottom:6px;\">Review-Text kopieren</li>\n                <li style=\"margin-bottom:6px;\">Google-Bewertung öffnen</li>\n                <li style=\"margin-bottom:6px;\">Text einfügen &amp; optional Fotos hochladen</li>\n                <li>Veröffentlichen</li>\n              </ol>\n              <table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" role=\"presentation\" style=\"margin: 0 0 28px;\">\n                <tr>\n                  <td style=\"background-color:#fff8f8; border: 1px solid #f0d0d0; padding: 14px 16px; border-radius:4px;\">\n                    <p style=\"margin:0; font-size:13px; color:#CF2030; font-weight:700;\">Profi-Tipp:</p>\n                    <p style=\"margin:6px 0 0; font-size:13px; color:#555555;\">Rezensionen mit Fotos werden von Google deutlich häufiger ausgespielt. Lade 1–2 Schnappschüsse direkt beim Posten hoch!</p>\n                  </td>\n                </tr>\n              </table>\n              {{ $json.has_gbp_link\n                ? '<table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" role=\"presentation\"><tr><td align=\"center\" style=\"padding-bottom:24px;\"><a href=\"' + $json.google_review_link + '\" style=\"display:inline-block; background-color:#CF2030; color:#ffffff; text-decoration:none; font-size:14px; font-weight:700; padding:12px 28px; border-radius:25px;\">Google-Bewertung öffnen</a></td></tr></table>'\n                : '<p style=\"font-size:13px; color:#888888; margin:0 0 24px;\">Hinweis: Für dieses Unternehmen ist aktuell kein Google-Profil hinterlegt.</p>' }}\n            </td>\n          </tr>\n          <tr>\n            <td style=\"background-color:#f9f9f9; border-top:1px solid #eeeeee; padding: 20px 32px; text-align:center;\">\n              <p style=\"margin:0; font-size:12px; color:#aaaaaa;\">Vielen Dank für deine Unterstützung!<br>Dein Your Agency Team</p>\n            </td>\n          </tr>\n        </table>\n      </td>\n    </tr>\n  </table>\n</body>\n</html>\n",
        "options": {}
      },
