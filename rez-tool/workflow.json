    },
    {
      "parameters": {
        "jsCode": "// GBP-Zuordnung direkt im Code-Node (ohne Google-Sheet-Lookup)\nconst cleaningData = $('Cleaning').first().json;\nconst reviewData = $('Review Schreiber 2').first().json;\n\nconst normalizeSlug = (value) => String(value || '')\n  .normalize('NFD')\n  .replace(/[\\u0300-\\u036f]/g, '')\n  .toLowerCase()\n  .replace(/[^a-z0-9]+/g, '_')\n  .replace(/^_+|_+$/g, '');\n\n// Hier Place IDs pflegen: slug -> place_id\nconst PLACE_ID_BY_SLUG = {\n  member_01: 'ChIJ_EXAMPLE_PLACE_ID',\n  member_02: 'ChIJ_EXAMPLE_PLACE_ID',\n  member_03: 'ChIJ_EXAMPLE_PLACE_ID',\n  member_04: 'ChIJ_EXAMPLE_PLACE_ID',\n  member_05: 'ChIJ_EXAMPLE_PLACE_ID',\n  member_06: 'ChIJ_EXAMPLE_PLACE_ID',\n  member_07: 'ChIJ_EXAMPLE_PLACE_ID',\n  member_08: 'ChIJ_EXAMPLE_PLACE_ID',\n  member_09: 'ChIJ_EXAMPLE_PLACE_ID',\n  member_10: 'ChIJ_EXAMPLE_PLACE_ID',\n  member_11: 'ChIJ_EXAMPLE_PLACE_ID',\n  member_12: 'ChIJ_EXAMPLE_PLACE_ID',\n  member_13: 'ChIJ_EXAMPLE_PLACE_ID',\n  member_14: 'ChIJ_EXAMPLE_PLACE_ID',\n  member_15: 'ChIJ_EXAMPLE_PLACE_ID',\n  member_16: 'ChIJ_EXAMPLE_PLACE_ID',\n  member_17: 'ChIJ_EXAMPLE_PLACE_ID',\n  member_18: 'ChIJ_EXAMPLE_PLACE_ID',\n  member_19: 'ChIJ_EXAMPLE_PLACE_ID',\n  member_20: 'ChIJ_EXAMPLE_PLACE_ID',\n  member_21: 'ChIJ_EXAMPLE_PLACE_ID',\n  member_22: 'ChIJ_EXAMPLE_PLACE_ID',\n  member_23: 'ChIJ_EXAMPLE_PLACE_ID',\n  // Offene IDs laut aktuellem Stand:\n  // marco_wehrmann: '',\n  // matthias_rogge: '',\n  // michael_pabst: '',\n};\n\nconst groupedAliases = [\n  ['member_09', 'member_10', 'wehrmann_immobilien', 'kabelanschluss24_com_gmbh']\n];\n\nconst companySlug = normalizeSlug(cleaningData.company || '');\nlet placeId = PLACE_ID_BY_SLUG[companySlug] || '';\n\nif (!placeId) {\n  for (const group of groupedAliases) {\n    if (!group.includes(companySlug)) continue;\n\n    const firstMatch = group.find((slug) => PLACE_ID_BY_SLUG[slug]);\n    if (firstMatch) {\n      placeId = PLACE_ID_BY_SLUG[firstMatch];\n    }\n    break;\n  }\n}\n\nconst reviewLink = placeId\n  ? `https://search.google.com/local/writereview?placeid=${placeId}`\n  : '';\n\nconst rawReview = $input.first().json.content || 'Review konnte nicht generiert werden';\n\n// Rekursive Reinigung\nlet text = rawReview;\nlet oldText;\ndo {\n  oldText = text;\n  text = text\n    .replace(/^[\\s\\S]*?(Rezension|Review|Output|Input|Sterne|Feedback|Kommentar|Vorschlag|Ergebnis|Zusammenfassung).*?[:\\-]+\\s*/si, '')\n    .trim();\n} while (text !== oldText);\n\nconst reviewText = text\n  .replace(/---/g, '')\n  .replace(/^[\\s\"'„&]+|[\\s\"'“]+$/g, '')\n  .trim();\n\nconst fullData = {\n  name: cleaningData.name,\n  email: cleaningData.email,\n  company: cleaningData.company,\n  company_name: cleaningData.company_name || cleaningData.company,\n  rating: cleaningData.rating,\n  positive_feedback: cleaningData.positive_feedback,\n  improvement: cleaningData.improvement,\n  notes: cleaningData.notes,\n  timestamp: cleaningData.timestamp,\n  google_review_link: reviewLink,\n  has_gbp_link: Boolean(placeId),\n  support_forwarded: false,\n  ai_generated_review: reviewText,\n  critical_review_output: ''\n};\n\nreturn [{ json: fullData, pairedItem: { item: 0 } }];\n"
      },
