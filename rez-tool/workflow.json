      "parameters": {
        "jsCode": "const body = $input.first().json.body;\n\nreturn {\n  json: {\n    timestamp: new Date().toISOString(),\n    name: body.name,\n    email: body.email,\n    company: body.company,\n    company_name: body.company_name || body.company,\n    rating: body.rating + ' Sterne',\n    rating_number: Number(body.rating),\n    positive_feedback: body.likes,\n    improvement: body.improvements || 'Keine Angabe',\n    notes: body.notes || 'Keine Angabe'\n  }\n};\n"
      },
