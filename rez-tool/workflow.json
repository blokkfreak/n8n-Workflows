        "html": "=<!DOCTYPE html>\n<html lang=\"de\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>Kritische Rezension eingegangen</title>\n</head>\n<body style=\"margin:0; padding:0; background-color:#f4f4f4; font-family: Arial, Helvetica, sans-serif;\">\n  <table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" role=\"presentation\" style=\"background-color:#f4f4f4;\">\n    <tr>\n      <td align=\"center\" style=\"padding: 32px 16px;\">\n        <table width=\"600\" cellpadding=\"0\" cellspacing=\"0\" role=\"presentation\" style=\"max-width:600px; width:100%; background-color:#ffffff; border-radius:8px; overflow:hidden;\">\n          <tr>\n            <td style=\"background-color:#CF2030; padding: 28px 32px; text-align:center;\">\n              <h1 style=\"margin:0; color:#ffffff; font-size:22px; font-weight:700;\">Kritische Rezension eingegangen</h1>\n            </td>\n          </tr>\n          <tr>\n            <td style=\"padding: 32px;\">\n              <p style=\"margin:0 0 20px; font-size:14px; color:#333333;\">Es ist soeben eine kritische Bewertung über das Rezensionstool eingegangen. Bitte prüft den Vorgang und nehmt ggf. Kontakt zum Kunden auf.</p>\n              <table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" role=\"presentation\" style=\"margin: 0 0 20px; border:1px solid #eeeeee; border-radius:4px;\">\n                <tr><td colspan=\"2\" style=\"background:#CF2030; padding:10px 16px; border-radius:4px 4px 0 0;\"><p style=\"margin:0; font-size:11px; font-weight:700; color:#ffffff; text-transform:uppercase; letter-spacing:1px;\">Kundendaten</p></td></tr>\n                <tr><td style=\"padding:10px 16px; font-size:13px; color:#888888; width:140px; border-bottom:1px solid #f5f5f5;\">Name</td><td style=\"padding:10px 16px; font-size:13px; color:#333333; font-weight:600; border-bottom:1px solid #f5f5f5;\">{{ $('Cleaning').item.json.name }}</td></tr>\n                <tr style=\"background:#f9f9f9;\"><td style=\"padding:10px 16px; font-size:13px; color:#888888; border-bottom:1px solid #eeeeee;\">E-Mail</td><td style=\"padding:10px 16px; font-size:13px; color:#333333; font-weight:600; border-bottom:1px solid #eeeeee;\">{{ $('Cleaning').item.json.email }}</td></tr>\n                <tr><td style=\"padding:10px 16px; font-size:13px; color:#888888; border-bottom:1px solid #f5f5f5;\">Firma</td><td style=\"padding:10px 16px; font-size:13px; color:#333333; font-weight:600; border-bottom:1px solid #f5f5f5;\">{{ $('Cleaning').item.json.company_name }}</td></tr>\n                <tr style=\"background:#f9f9f9;\"><td style=\"padding:10px 16px; font-size:13px; color:#888888;\">Zeitpunkt</td><td style=\"padding:10px 16px; font-size:13px; color:#333333; font-weight:600;\">{{ $('Cleaning').item.json.timestamp }}</td></tr>\n              </table>\n              <table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" role=\"presentation\" style=\"margin: 0 0 20px; border:1px solid #eeeeee; border-radius:4px;\">\n                <tr><td colspan=\"2\" style=\"background:#CF2030; padding:10px 16px; border-radius:4px 4px 0 0;\"><p style=\"margin:0; font-size:11px; font-weight:700; color:#ffffff; text-transform:uppercase; letter-spacing:1px;\">Bewertung</p></td></tr>\n                <tr><td style=\"padding:10px 16px; font-size:13px; color:#888888; width:140px; border-bottom:1px solid #f5f5f5;\">Sterne</td><td style=\"padding:10px 16px; font-size:13px; color:#CF2030; font-weight:700; border-bottom:1px solid #f5f5f5;\">{{ $('Cleaning').item.json.rating }}</td></tr>\n                <tr style=\"background:#f9f9f9;\"><td style=\"padding:10px 16px; font-size:13px; color:#888888; border-bottom:1px solid #eeeeee;\">Was war gut</td><td style=\"padding:10px 16px; font-size:13px; color:#333333; border-bottom:1px solid #eeeeee;\">{{ $('Cleaning').item.json.positive_feedback }}</td></tr>\n                <tr><td style=\"padding:10px 16px; font-size:13px; color:#888888; border-bottom:1px solid #f5f5f5;\">Kritik</td><td style=\"padding:10px 16px; font-size:13px; color:#333333; border-bottom:1px solid #f5f5f5;\">{{ $('Cleaning').item.json.improvement }}</td></tr>\n                <tr style=\"background:#f9f9f9;\"><td style=\"padding:10px 16px; font-size:13px; color:#888888;\">Kommentar</td><td style=\"padding:10px 16px; font-size:13px; color:#333333;\">{{ $('Cleaning').item.json.notes }}</td></tr>\n              </table>\n              <p style=\"margin:0 0 8px; font-size:14px; color:#333333; font-weight:700;\">Generierter Review-Text:</p>\n              <table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" role=\"presentation\">\n                <tr>\n                  <td style=\"background-color:#f9f9f9; border-left: 4px solid #CF2030; padding: 16px 16px 16px 12px; border-radius:0 4px 4px 0;\">\n                    <p style=\"margin:0; font-size:14px; color:#333333; line-height:1.7; font-style:italic;\">{{ ($json.content || '').toString().replace(/^[\\s\\S]*?(Rezension|Review|Output|Input|Sterne|Feedback|Kommentar|Vorschlag|Ergebnis|Zusammenfassung).*?[:\\-]+\\s*/si, '').replace(/---/g, '').replace(/^[\\s\"']+|[\\s\"']+$/g, '').trim() }}</p>\n                  </td>\n                </tr>\n              </table>\n            </td>\n          </tr>\n          <tr>\n            <td style=\"background-color:#f9f9f9; border-top:1px solid #eeeeee; padding: 20px 32px; text-align:center;\">\n              <p style=\"margin:0; font-size:12px; color:#aaaaaa;\">Automatisch generiert &mdash; Rezensionstool &middot; Your Agency</p>\n            </td>\n          </tr>\n        </table>\n      </td>\n    </tr>\n  </table>\n</body>\n</html>\n",
