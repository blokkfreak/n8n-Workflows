        "options": {}
      },
      "type": "@n8n/n8n-nodes-langchain.lmChatOpenRouter",
      "typeVersion": 1,
      "position": [
        -256,
        416
      ],
      "id": "e7dbb178-1557-4bd5-9788-ed80840168bf",
      "name": "OpenRouter Chat Model",
      "credentials": {
