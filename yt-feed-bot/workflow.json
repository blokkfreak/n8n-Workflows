    },
    {
      "parameters": {
        "promptType": "define",
        "text": "=Du bist ein präziser Assistent. Fasse den Inhalt eines YouTube-Videos in maximal 2-3 Sätzen auf Deutsch zusammen. Nur die Zusammenfassung, kein Intro, keine Floskeln. Verwende keine Markdown-Formatierung. Kein **fett**, kein _kursiv_, keine Listen.\n\nTitel: {{ $json.title }}\nBeschreibung: {{ ($json.contentSnippet || $json.content || $json.summary || 'Keine Beschreibung verfügbar').substring(0, 600) }}",
        "batching": {
          "batchSize": 1,
          "delayBetweenBatches": 3000
        }
      },
      "type": "@n8n/n8n-nodes-langchain.chainLlm",
      "typeVersion": 1.9,
      "position": [
        -256,
        192
      ],
